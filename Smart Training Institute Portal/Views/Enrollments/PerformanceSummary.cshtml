@model IEnumerable<Smart_Training_Institute_Portal.Models.Enrollment>

@{
    ViewData["Title"] = "Performance Summary";
}

<h1>Performance Summary</h1>

<div class="card mb-4">
    <div class="card-body">
        <h5>Average Mark: @ViewBag.AverageMark?.ToString("0.00")</h5>
        <h5>Total Completed Courses: @ViewBag.TotalCourses</h5>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Course Title</th>
            <th>Grade</th>
            <th>Mark</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Course?.Title</td>
                <td>@item.Grade</td>
                <td>@item.Mark</td>
            </tr>
        }
    </tbody>
</table>