@model IEnumerable<Smart_Training_Institute_Portal.Models.Enrollment>

@{
    ViewData["Title"] = "My Courses";
}

<h1>My Courses</h1>

<table class="table">
    <thead>
        <tr>
            <th>Course Title</th>
            <th>Department</th>
            <th>Enrollment Date</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Course?.Title</td>
                <td>@item.Course?.Department?.Name</td>
                <td>@item.EnrollmentDate.ToShortDateString()</td>
                <td>@item.Status</td>
            </tr>
        }
    </tbody>
</table>