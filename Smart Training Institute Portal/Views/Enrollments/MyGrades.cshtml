@model IEnumerable<Smart_Training_Institute_Portal.Models.Enrollment>

@{
    ViewData["Title"] = "My Grades";
}

<h1>My Grades</h1>

<table class="table">
    <thead>
        <tr>
            <th>Course Title</th>
            <th>Grade</th>
            <th>Mark</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Course?.Title</td>
                <td>@item.Grade</td>
                <td>@item.Mark</td>
            </tr>
        }
    </tbody>
</table>