@model Smart_Training_Institute_Portal.Models.InstructorProfile

@{
    ViewData["Title"] = "Create Instructor";
}

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <h1 class="page-title"><i class="bi bi-person-plus me-2 text-danger"></i>Create Instructor</h1>
        <p class="page-subtitle">Add instructor details, specialization, and office info.</p>
    </div>
    <div class="sti-action-bar">
        <a asp-action="Index" class="btn btn-danger">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card sti-card">
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="InstructorNumber" class="form-control" placeholder="Instructor Number" />
                                <label asp-for="InstructorNumber" class="fw-semibold"></label>
                            </div>
                            <span asp-validation-for="InstructorNumber" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="FullName" class="form-control" placeholder="Full Name" />
                                <label asp-for="FullName" class="fw-semibold"></label>
                            </div>
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="Specialization" class="form-control" placeholder="Specialization" />
                                <label asp-for="Specialization" class="fw-semibold"></label>
                            </div>
                            <span asp-validation-for="Specialization" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="OfficeNumber" class="form-control" placeholder="Office Number" />
                                <label asp-for="OfficeNumber" class="fw-semibold"></label>
                            </div>
                            <span asp-validation-for="OfficeNumber" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-floating">
                                <input asp-for="Bio" class="form-control" placeholder="Bio" />
                                <label asp-for="Bio" class="fw-semibold"></label>
                            </div>
                            <span asp-validation-for="Bio" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input asp-for="ImageUrl" class="form-control" placeholder="Image Url" />
                                <label asp-for="ImageUrl" class="fw-semibold"></label>
                            </div>
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="ApplicationUserId" class="form-select" asp-items="ViewBag.ApplicationUserId"></select>
                                <label asp-for="ApplicationUserId" class="fw-semibold"></label>
                            </div>
                            <span asp-validation-for="ApplicationUserId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-danger">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-1"></i> Create
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
