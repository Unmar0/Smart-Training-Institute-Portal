@model Smart_Training_Institute_Portal.ViewModels.UserDetailsViewModel

@{
    ViewData["Title"] = "User Details";
}

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <h1 class="page-title"><i class="bi bi-person-vcard me-2 text-danger"></i>User Details</h1>
        <p class="page-subtitle">Review account information and assigned access.</p>
    </div>
    <div class="sti-action-bar d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            Edit
        </a>
        <a asp-action="Index" class="btn btn-danger">
            Back to List
        </a>
    </div>
</div>

<div class="card sti-card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.UserName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.UserName)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PhoneNumber)</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "-" : Model.PhoneNumber)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Role)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Role)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EmailConfirmed)</dt>
            <dd class="col-sm-9">@(Model.EmailConfirmed ? "Yes" : "No")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.HasStudentProfile)</dt>
            <dd class="col-sm-9">@(Model.HasStudentProfile ? "Linked" : "Not Linked")</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.HasInstructorProfile)</dt>
            <dd class="col-sm-9">@(Model.HasInstructorProfile ? "Linked" : "Not Linked")</dd>
        </dl>
    </div>
</div>
