@model IEnumerable<Smart_Training_Institute_Portal.ViewModels.UserListItemViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <h1 class="page-title"><i class="bi bi-people me-2 text-danger"></i>Users</h1>
        <p class="page-subtitle">Manage login accounts, roles, and access for the portal.</p>
    </div>
    <div class="sti-action-bar">
        <a asp-action="Create" class="btn btn-primary">
            Create New
        </a>
    </div>
</div>

<div class="card sti-card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle sti-table">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.UserName)</th>
                        <th>@Html.DisplayNameFor(model => model.Email)</th>
                        <th>@Html.DisplayNameFor(model => model.PhoneNumber)</th>
                        <th>@Html.DisplayNameFor(model => model.Role)</th>
                        <th>@Html.DisplayNameFor(model => model.EmailConfirmed)</th>
                        <th>Linked Profiles</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.UserName)</td>
                                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.PhoneNumber) ? "-" : item.PhoneNumber)</td>
                                <td>@Html.DisplayFor(modelItem => item.Role)</td>
                                <td>@(item.EmailConfirmed ? "Yes" : "No")</td>
                                <td>
                                    @(item.HasStudentProfile ? "Student " : string.Empty)@(item.HasInstructorProfile ? "Instructor" : string.Empty)
                                    @if (!item.HasStudentProfile && !item.HasInstructorProfile)
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm" title="Edit" aria-label="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm" title="Details" aria-label="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm" title="Delete" aria-label="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="sti-empty-state text-center py-5">
                                    <i class="bi bi-inbox fs-1 text-danger"></i>
                                    <h5 class="mt-3">No users found</h5>
                                    <p class="text-muted">Create a new account to start managing portal access.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
