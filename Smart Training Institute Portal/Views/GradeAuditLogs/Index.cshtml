@model IEnumerable<Smart_Training_Institute_Portal.Models.GradeAuditLog>

@{
    ViewData["Title"] = "Grade Audit Logs";
}

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <h1 class="page-title"><i class="bi bi-clock-history me-2 text-danger"></i>Grade Audit Logs</h1>
        <p class="page-subtitle">Review grade changes and audit activity for student assessments.</p>
    </div>
</div>

<div class="card sti-card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle sti-table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Student</th>
            <th>Course</th>
            <th>Old Grade</th>
            <th>New Grade</th>
            <th>Changed By</th>
            <th></th>
        </tr>
    </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                            <td>@item.Enrollment?.StudentProfile?.FullName</td>
                            <td>@item.Enrollment?.Course?.Title</td>
                            <td><span class="badge sti-badge">@item.OldGrade</span></td>
                            <td><span class="badge sti-badge">@item.NewGrade</span></td>
                            <td>@item.ChangedByUser?.Email</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-eye me-1"></i> Details
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="sti-empty-state text-center py-5">
                                <i class="bi bi-inbox fs-1 text-danger"></i>
                                <h5 class="mt-3">No records found</h5>
                                <p class="text-muted">Grade changes will appear here once updates are made.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
