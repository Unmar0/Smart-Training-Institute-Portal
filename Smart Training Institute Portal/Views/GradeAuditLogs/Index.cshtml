@model IEnumerable<Smart_Training_Institute_Portal.Models.GradeAuditLog>

@{
    ViewData["Title"] = "Grade Audit Logs";
}

<h1>Grade Audit Logs</h1>

<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Student</th>
            <th>Course</th>
            <th>Old Grade</th>
            <th>New Grade</th>
            <th>Changed By</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CreatedAt.ToLocalTime().ToString("g")</td>
                <td>@item.Enrollment?.StudentProfile?.FullName</td>
                <td>@item.Enrollment?.Course?.Title</td>
                <td>@item.OldGrade</td>
                <td>@item.NewGrade</td>
                <td>@item.ChangedByUser?.Email</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>