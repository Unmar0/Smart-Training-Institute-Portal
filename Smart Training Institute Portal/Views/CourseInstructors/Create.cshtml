@model Smart_Training_Institute_Portal.Models.CourseInstructor

@{
    ViewData["Title"] = "Assign Instructor";
}

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <h1 class="page-title"><i class="bi bi-person-check me-2 text-danger"></i>Assign Instructor</h1>
        <p class="page-subtitle">Connect an instructor profile to a course.</p>
    </div>
    <div class="sti-action-bar">
        <a asp-action="Index" class="btn btn-danger">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card sti-card">
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId"></select>
                                <label asp-for="CourseId" class="fw-semibold"></label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="InstructorProfileId" class="form-select" asp-items="ViewBag.InstructorProfileId"></select>
                                <label asp-for="InstructorProfileId" class="fw-semibold"></label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-danger">
                            <i class="bi bi-arrow-left me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-plus-circle me-1"></i> Assign
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
