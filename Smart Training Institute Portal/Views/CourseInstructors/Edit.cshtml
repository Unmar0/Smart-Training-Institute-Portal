@model Smart_Training_Institute_Portal.Models.CourseInstructor

@{
    ViewData["Title"] = "Edit Assignment";
}

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <h1 class="page-title"><i class="bi bi-pencil-square me-2 text-danger"></i>Edit Assignment</h1>
        <p class="page-subtitle">Update the course instructor assignment.</p>
    </div>
    <div class="sti-action-bar">
        <a asp-action="Index" class="btn btn-danger">
            Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card sti-card">
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="CourseId" class="form-select" asp-items="ViewBag.CourseId"></select>
                                <label asp-for="CourseId" class="fw-semibold"></label>
                            </div>
                            <span asp-validation-for="CourseId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select asp-for="InstructorProfileId" class="form-select" asp-items="ViewBag.InstructorProfileId"></select>
                                <label asp-for="InstructorProfileId" class="fw-semibold"></label>
                            </div>
                            <span asp-validation-for="InstructorProfileId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-danger">
                            Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            Save
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
